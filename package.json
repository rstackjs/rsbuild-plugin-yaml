{
  "name": "@rsbuild/plugin-yaml",
  "version": "2.0.0",
  "homepage": "https://github.com/rstackjs/rsbuild-plugin-yaml#readme",
  "bugs": {
    "url": "https://github.com/rstackjs/rsbuild-plugin-yaml/issues"
  },
  "repository": "https://github.com/rstackjs/rsbuild-plugin-yaml",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "bump": "pnpx bumpp",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks",
    "test": "rstest"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.1.2",
    "@rslib/core": "^0.23.2",
    "@rslint/core": "^0.6.4",
    "@rstest/core": "^0.11.1",
    "@rstest/playwright": "^0.11.1",
    "@types/node": "^24.13.2",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^7.0.2",
    "yaml-loader": "^0.9.0"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
